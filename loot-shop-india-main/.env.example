# ==========================================
# Core Application
# ==========================================
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# ==========================================
# AI Provider Configuration
# ==========================================
# Options: lovable, openrouter, gemini, groq, deepseek, mistral, together, novita, replicate, nim, huggingface, custom
# If left blank or invalid, the system automatically defaults to 'lovable'.
AI_DEFAULT_PROVIDER="lovable"
AI_FALLBACK_PROVIDER="lovable"

# Global default model (used if provider-specific model is not set)
AI_DEFAULT_MODEL=""

# Legacy Lovable Gateway (Default Fallback)
LOVABLE_API_KEY=""
LOVABLE_MODEL="google/gemini-3-flash-preview"

# OpenRouter Specific Headers (Optional but recommended for OpenRouter)
OPENROUTER_REFERER="https://lootbazaar.in"
OPENROUTER_TITLE="LootBazaar"

# ==========================================
# OpenAI-Compatible Providers 
# (OpenRouter, Groq, DeepSeek, Mistral, Together, Novita, Replicate, NIM, Custom)
# The manager dynamically maps the provider name to these variables.
# ==========================================
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o"

GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-70b-versatile"

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-small"

TOGETHER_API_KEY=""
TOGETHER_MODEL="meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo"

NOVITA_API_KEY=""
NOVITA_MODEL="meta-llama/llama-3.1-70b-instruct"

REPLICATE_API_KEY=""
REPLICATE_MODEL="meta/meta-llama-3-70b-instruct"

NIM_API_KEY=""
NIM_BASE_URL="https://integrate.api.nvidia.com/v1"
NIM_MODEL="meta/llama-3.1-70b-instruct"

CUSTOM_API_KEY=""
CUSTOM_BASE_URL=""
CUSTOM_MODEL=""

# ==========================================
# Non-OpenAI-Compatible Providers
# ==========================================
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# Note: For Hugging Face, ensure HUGGINGFACE_BASE_URL points to an OpenAI-compatible Inference Endpoint.
HUGGINGFACE_API_KEY=""
HUGGINGFACE_BASE_URL="https://api-inference.huggingface.co/v1"
HUGGINGFACE_MODEL="meta-llama/Meta-Llama-3-8B-Instruct"

